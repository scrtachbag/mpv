# Copier en .env.local pour le dev local. Pour la prod, définir ces variables
# dans GitHub : Settings > Secrets and variables > Actions.
#
# ⚠️ Ce sont des clés PUBLIQUES (préfixe VITE_, embarquées dans le bundle).
#    N'y mets JAMAIS la clé service_role : seules l'URL et la clé "anon".

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...   # clé "anon public"

# (Optionnel) Lien direct vers le workflow Actions "Résultats du soir", affiché
# dans le panneau admin. Laisser vide sinon.
# Ex : https://github.com/<user>/mon-petit-velo/actions/workflows/results.yml
VITE_MPV_ACTIONS_URL=
