# Secrets de l'Edge Function trigger-results.
#
# En local : copier en supabase/functions/.env puis :
#   npx supabase functions serve trigger-results --env-file supabase/functions/.env
#
# En prod : npx supabase secrets set GH_DISPATCH_TOKEN=... GH_REPO=... GH_REF=main
#
# GH_DISPATCH_TOKEN : PAT GitHub *fine-grained*, permission "Actions: write"
#                     limitée au dépôt mon-petit-velo. NE JAMAIS committer.
GH_DISPATCH_TOKEN=github_pat_xxx
GH_REPO=ton-user/mon-petit-velo
GH_REF=main
