# Variables des jobs Python. En CI : Settings > Secrets and variables > Actions.
# Pour un test local : copier en jobs/.env et `set -a; . ./.env; set +a` avant de lancer.

SUPABASE_URL=http://127.0.0.1:54321
# Clé service_role (JWT 'eyJ...'). En local : `npx supabase status` -> SERVICE_ROLE_KEY.
# En prod : Supabase > Project Settings > API > service_role. NE PAS committer.
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# Course
MPV_SEASON=2026
MPV_RACE_SLUG=tour-de-france

# Notifications push (Web Push / VAPID) — paire générée via `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=BEyrbOxe...              # identique à VITE_VAPID_PUBLIC_KEY du front
VAPID_PRIVATE_KEY=xxxxxxxx                # SECRET
VAPID_SUBJECT=mailto:toi@exemple.fr
MPV_SITE_URL=https://ton-user.github.io/mon-petit-velo/
